# Copy to .env and edit. The real .env is git-ignored.

# Random secret used to authenticate admin login.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=changeme

# Public site URL — used for absolute URLs in OG meta tags + OAuth callback.
SITE_URL=https://slopcard.org

NODE_ENV=production

# Random secret used to sign user-session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=changeme

# X / Twitter OAuth 2.0 credentials (developer.x.com).
# Required for "Sign in with X" to work; leave empty to disable.
# Callback URL to register with X: {SITE_URL}/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── /discover (LLM-powered Swapcard attendee recommendations) ─────────────────

# OpenRouter API key for the two LLM calls in the discover pipeline.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter model slug (default: google/gemini-2.5-flash). Override for
# better quality with e.g. anthropic/claude-sonnet-4-6.
SWAPCARD_LLM_MODEL=anthropic/claude-opus-4.8

# Comma-separated handles that may use the server's OPENROUTER_API_KEY without
# bringing their own key. Anyone else hitting /discover is prompted for a key.
SWAPCARD_FREE_HANDLES=

# Internal event id used as cache key. Change when supporting a different
# conference. The Swapcard URL the user pastes is validated by host + path
# shape (not by this id), so a typo here doesn't break verification.
SWAPCARD_EVENT_ID=eag-london-2026

# Override the attendee Google Sheet (defaults to the public EAG London 2026
# sheet baked into the code). SHEET_GID is the tab id within the spreadsheet.
SWAPCARD_SHEET_ID=
SWAPCARD_SHEET_GID=

# Calendar export — set to a long random string to enable .ics subscription
# links on /agenda. Leave empty to disable the export buttons.
SWAPCARD_AGENDA_PUBLIC_TOKEN=

# SMS approval flow (optional — leave empty to disable approval gate)
SWAPCARD_REQUIRE_APPROVAL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
ADMIN_PHONE=
